{
  "manifest_version": 3,
  "name": "Token Optimizer",
  "version": "1.1",
  "description": "Optimize AI chatbot inputs to save tokens and costs in real-time.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["optimizer.js", "content.js"],
      "css": ["styles.css"],
      "all_frames": true
    }
  ]
}
